{
  "name": "lark-codex",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu/Lark-native Codex bridge for direct chat and group workflows.",
  "type": "module",
  "bin": {
    "lark-codex": "./bin/lark-codex.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "install:local": "./install.sh",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/index.ts --cli",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dotenv": "^16.6.1",
    "node-pty": "^1.1.0",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
