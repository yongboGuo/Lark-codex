NODE_ENV=development
PORT=3300
LOG_LEVEL=info

FEISHU_APP_ID=cli_PLACEHOLDER
FEISHU_APP_SECRET=PLACEHOLDER
FEISHU_BOT_OPEN_ID=ou_PLACEHOLDER
FEISHU_CONNECTION_MODE=websocket

CODEX_BIN=/opt/node/bin/codex
CODEX_PROFILE_MODE=isolated
CODEX_HOME=/home/yuiwong/.codex-feishu-bridge-dev
CODEX_SESSIONS_DIR=/home/yuiwong/.codex-feishu-bridge-dev/sessions
CODEX_BACKEND_MODE=spawn
CODEX_SANDBOX_MODE=workspace-write
CODEX_RUN_TIMEOUT_MS=600000
WORKSPACE_ROOT=/volumes/ws/codex-feishu-bridge
DEFAULT_WORKSPACE=/volumes/ws/codex-feishu-bridge

STORE_PATH=.data/bindings.json
