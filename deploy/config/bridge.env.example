NODE_ENV=development
PORT=3300
LOG_LEVEL=info

FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_BOT_OPEN_ID=replace-me
FEISHU_CONNECTION_MODE=websocket

CODEX_PROFILE_MODE=isolated
CODEX_BIN=/opt/node/bin/codex
CODEX_HOME=$HOME/.codex-feishu-bridge
CODEX_SESSIONS_DIR=$HOME/.codex-feishu-bridge/sessions

WORKSPACE_ROOT=/volumes/ws/codex-feishu-bridge
DEFAULT_WORKSPACE=/volumes/ws/codex-feishu-bridge
STORE_PATH=$HOME/.local/share/codex-feishu-bridge/bindings.json
BRIDGE_CONFIG_JSON=$HOME/.config/codex-feishu-bridge/config.json
