NODE_ENV=development

FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_BOT_OPEN_ID=replace-me
FEISHU_CONNECTION_MODE=websocket
# Optional: send a one-time "Lark Codex Ready" message after websocket connect and
# outbound Feishu send are both working.
# FEISHU_STARTUP_NOTIFY_CHAT_ID=oc_xxx
# Recommended for production:
# FEISHU_ALLOWED_OPEN_IDS=ou_xxx,ou_yyy
# FEISHU_ALLOWED_CHAT_IDS=oc_xxx
# FEISHU_ALLOW_ALL_OPEN_IDS=false
# FEISHU_GROUP_REQUIRE_MENTION=true
# FEISHU_GROUP_REQUIRE_COMMAND_PREFIX=false
# FEISHU_COMMAND_PREFIX=codex
# FEISHU_REPLY_MODE=reply

BRIDGE_CONFIG_JSON=$HOME/.config/lark-codex/config.json

# Optional network/proxy settings for the service and spawned Codex runs.
# HTTP_PROXY=http://127.0.0.1:7897/
# HTTPS_PROXY=http://127.0.0.1:7897/
# NO_PROXY=localhost,127.0.0.1,::1,.feishu.cn,open.feishu.cn
# http_proxy=http://127.0.0.1:7897/
# https_proxy=http://127.0.0.1:7897/
# no_proxy=localhost,127.0.0.1,::1,.feishu.cn,open.feishu.cn
# NODE_EXTRA_CA_CERTS=/path/to/custom-ca.crt
