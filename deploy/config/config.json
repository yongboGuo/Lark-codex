{
  "app": {
    "logLevel": "info",
    "port": 3300
  },
  "feishu": {
    "wsLoggerLevel": "info",
    "reconnectReadyDebounceMs": 60000,
    "sendRetry": {
      "maxAttempts": 5,
      "baseDelayMs": 1000,
      "multiplier": 2,
      "maxDelayMs": 10000
    }
  },
  "codex": {
    "bin": "codex",
    "profileMode": "isolated",
    "home": "$HOME/.codex-feishu-bridge",
    "sessionsDir": "$HOME/.codex-feishu-bridge/sessions",
    "backendMode": "app-server",
    "sandboxMode": "default",
    "runTimeoutMs": 600000,
    "approvalTimeoutMs": 180000,
    "spawn": {
      "statusIntervalMs": 30000
    },
    "terminal": {
      "renderMode": "markdown",
      "flushIdleMs": 3000,
      "flushMaxChars": 4000,
      "startupTimeoutMs": 30000
    }
  },
  "session": {
    "listDefaultCount": 20,
    "allDefaultCount": 100
  },
  "project": {
    "allowedRoots": [
      "$HOME"
    ],
    "defaultPath": "$HOME",
    "defaultSearchEnabled": true
  },
  "status": {
    "includeProject": true
  },
  "paths": {
    "storePath": "$HOME/.local/share/codex-feishu-bridge/bindings.json"
  }
}
